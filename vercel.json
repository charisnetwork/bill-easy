{
  "version": 2,
  "builds": [
    {
      "src": "frontend/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "frontend/dist"
      }
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "https://industrious-harmony-production-6331.up.railway.app/api/$1"
    },
    {
      "source": "/uploads/(.*)",
      "destination": "https://industrious-harmony-production-6331.up.railway.app/uploads/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/frontend/dist/index.html"
    }
  ]
}
